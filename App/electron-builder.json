{
    "asar": true,
    "directories": {
      "output": "release/"
    },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.map",
      "!package.json",
      "!package-lock.json",
      {
        "from": "../dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "dist/assets/icons",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "splashImage": "dist/assets/icons/electron.bmp"
    }
  }