{
  "name": "app",
  "version": "1.0.0",
  "author": {
    "name": "apiiisit",
    "email": "apiiisit@outlook.com"
  },
  "private": true,
  "main": "app/main.js",
  "scripts": {
    "start": "npm-run-all -p start:app start:web",
    "start:web": "ng serve",
    "start:app": "wait-on tcp:4200 && npm run electron:tsc && electron . --serve",
    "build": "npm run electron:tsc && npm run build:web && electron-builder build --publish=never",
    "build:web": "ng build --base-href ./",
    "electron:tsc": "tsc -p tsconfig.serve.json"
  },
  "dependencies": {
    "@angular/animations": "^15.0.0",
    "@angular/common": "^15.0.0",
    "@angular/compiler": "^15.0.0",
    "@angular/core": "^15.0.0",
    "@angular/forms": "^15.0.0",
    "@angular/platform-browser": "^15.0.0",
    "@angular/platform-browser-dynamic": "^15.0.0",
    "@angular/router": "^15.0.0",
    "primeflex": "^3.3.0",
    "primeicons": "^6.0.1",
    "primeng": "^15.0.0",
    "rxjs": "~7.5.0",
    "sweetalert2": "^11.6.15",
    "tslib": "^2.3.0",
    "zone.js": "~0.12.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^15.0.4",
    "@angular/cli": "~15.0.4",
    "@angular/compiler-cli": "^15.0.0",
    "@types/jasmine": "~4.3.0",
    "electron": "^22.0.0",
    "electron-builder": "^23.6.0",
    "electron-debug": "^3.2.0",
    "electron-reloader": "^1.2.3",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~4.8.2",
    "wait-on": "^7.0.1"
  }
}